<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>H&S Group — Stratégie Data & IA</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Cormorant+Garamond:wght@500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #f5efe5;
      --bg-soft: #efe7da;
      --panel: rgba(255,255,255,0.72);
      --panel-strong: rgba(255,255,255,0.92);
      --panel-alt: #f8f3eb;
      --line: rgba(90,73,48,0.12);
      --line-strong: rgba(90,73,48,0.18);
      --text: #2b241d;
      --muted: #6f6357;
      --muted-2: #948676;
      --accent: #8f7757;
      --accent-2: #bca27f;
      --accent-3: #d9c3a3;
      --shadow: 0 14px 50px rgba(70,53,35,0.10);
      --shadow-soft: 0 6px 24px rgba(70,53,35,0.07);
      --radius-xl: 28px;
      --radius-lg: 22px;
      --radius-md: 16px;
      --radius-sm: 12px;
      --data: #7e6a4c;
      --data-bg: rgba(126,106,76,0.10);
      --data-border: rgba(126,106,76,0.22);
      --ia: #5e564d;
      --ia-bg: rgba(94,86,77,0.10);
      --ia-border: rgba(94,86,77,0.22);
      --trans: #aa8b61;
      --trans-bg: rgba(170,139,97,0.12);
      --trans-border: rgba(170,139,97,0.22);
      --lot1: #9a8260;
      --lot2: #7d6b57;
      --lot3: #c2aa86;
      --priority-1: #7a5845;
      --priority-2: #9a775c;
      --priority-3: #8f8b80;
      --priority-4: #aba295;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: Inter, sans-serif; color: var(--text); background:
      radial-gradient(circle at top left, rgba(255,255,255,.66), transparent 35%),
      radial-gradient(circle at bottom right, rgba(188,162,127,.18), transparent 30%),
      linear-gradient(180deg, #f7f1e8, #efe7da 60%, #f4ede4); height: 100vh; overflow: hidden; }
    body::before { content:''; position: fixed; inset:0; pointer-events:none; opacity:.5; background-image: linear-gradient(rgba(70,53,35,.018) 1px, transparent 1px), linear-gradient(90deg, rgba(70,53,35,.018) 1px, transparent 1px); background-size: 34px 34px; mask-image: radial-gradient(circle at center, black 55%, transparent 90%); }
    button, input, select { font: inherit; }
    img { display:block; max-width:100%; }

    .app { display:grid; grid-template-columns: 300px 1fr; grid-template-rows: 84px 1fr; height:100vh; }
    .topnav { grid-column:1/-1; display:flex; align-items:center; gap:18px; padding:18px 28px; backdrop-filter: blur(20px); background: rgba(247,241,232,.72); border-bottom:1px solid var(--line); position:relative; z-index:20; }
    .brand { display:flex; align-items:center; gap:16px; min-width:0; }
    .brand-logo { width:138px; height:40px; display:flex; align-items:center; }
    .brand-copy small { display:block; color:var(--muted); text-transform:uppercase; letter-spacing:.22em; font-size:10px; margin-bottom:4px; }
    .brand-copy strong { font-size:14px; font-weight:700; letter-spacing:.02em; }
    .topnav-divider { width:1px; height:36px; background:var(--line); }
    .topnav-search { position:relative; width:min(420px, 100%); }
    .topnav-search input { width:100%; height:46px; padding:0 18px 0 46px; border:1px solid var(--line); border-radius:999px; background: rgba(255,255,255,.58); color:var(--text); outline:none; box-shadow: inset 0 1px 0 rgba(255,255,255,.6); }
    .topnav-search input::placeholder { color:var(--muted-2); }
    .topnav-search .si { position:absolute; left:18px; top:50%; transform:translateY(-50%); color:var(--muted); font-size:16px; }
    .topnav-pills { margin-left:auto; display:flex; gap:6px; flex-wrap:wrap; padding:6px; border:1px solid var(--line); border-radius:999px; background:rgba(255,255,255,.42); box-shadow: inset 0 1px 0 rgba(255,255,255,.5); }
    .nav-pill { border:1px solid transparent; background: transparent; color:var(--muted); border-radius:999px; padding:10px 14px; font-size:12px; font-weight:600; cursor:pointer; transition:.2s ease; }
    .nav-pill:hover, .nav-pill.active { background:rgba(255,255,255,.94); color:var(--text); border-color:rgba(90,73,48,.08); box-shadow: 0 6px 18px rgba(70,53,35,.08); }
    .badge-count { display:inline-flex; align-items:center; justify-content:center; min-width:20px; height:20px; padding:0 6px; margin-left:6px; border-radius:999px; background:var(--text); color:white; font-size:10px; }

    .sidebar { padding:22px 18px 26px; border-right:1px solid var(--line); background: linear-gradient(180deg, rgba(255,255,255,.45), rgba(255,255,255,.18)); overflow:auto; }
    .sidebar-block, .stats-row { background: var(--panel); border:1px solid rgba(255,255,255,.55); box-shadow: var(--shadow-soft); backdrop-filter: blur(16px); border-radius:22px; }
    .stats-row { display:grid; grid-template-columns:1fr 1fr; gap:10px; padding:12px; margin-bottom:16px; }
    .stat-box { background: rgba(255,255,255,.58); border:1px solid var(--line); border-radius:16px; padding:14px 12px; text-align:center; }
    .stat-num { font-family:'Cormorant Garamond', serif; font-size:34px; line-height:1; }
    .stat-lbl { color:var(--muted); font-size:10px; text-transform:uppercase; letter-spacing:.14em; margin-top:6px; }
    .sidebar-block { padding:16px; margin-bottom:14px; }
    .s-label { font-size:10px; color:var(--muted); font-weight:700; text-transform:uppercase; letter-spacing:.18em; margin-bottom:10px; }
    .filter-chip-row { display:flex; flex-wrap:wrap; gap:8px; }
    .fchip, .ent-chip { border:1px solid var(--line); background: rgba(255,255,255,.66); color:var(--muted); border-radius:999px; padding:8px 12px; font-size:12px; cursor:pointer; transition:.18s ease; }
    .fchip:hover, .ent-chip:hover, .fchip.active-all, .ent-chip.active { color:var(--text); border-color:var(--line-strong); background:white; }
    .fchip.active-data { color:var(--data); border-color:var(--data-border); background:var(--data-bg); }
    .fchip.active-ia { color:var(--ia); border-color:var(--ia-border); background:var(--ia-bg); }
    .fchip.active-trans { color:var(--trans); border-color:var(--trans-border); background:var(--trans-bg); }
    .fchip.active-p1 { color:var(--priority-1); border-color:rgba(122,88,69,.22); background:rgba(122,88,69,.08); }
    .filter-select { width:100%; height:44px; border-radius:14px; border:1px solid var(--line); padding:0 14px; background: rgba(255,255,255,.72); color:var(--text); outline:none; }

    .main { overflow:auto; }
    .hero { padding:34px 34px 26px; }
    .hero-shell { background: linear-gradient(135deg, rgba(255,255,255,.86), rgba(255,255,255,.58)); border:1px solid rgba(255,255,255,.7); box-shadow: var(--shadow); border-radius: 34px; padding:28px 30px; position:relative; overflow:hidden; }
    .hero-shell::after { content:''; position:absolute; right:-80px; top:-90px; width:280px; height:280px; border-radius:50%; background: radial-gradient(circle, rgba(188,162,127,.24), transparent 60%); }
    .hero-eyebrow { color:var(--muted); text-transform:uppercase; letter-spacing:.18em; font-size:11px; margin-bottom:14px; }
    h1 { font-family:'Cormorant Garamond', serif; font-size:58px; line-height:.96; font-weight:600; max-width:920px; letter-spacing:-.02em; margin-bottom:16px; }
    .hero-sub { max-width:760px; font-size:15px; color:var(--muted); line-height:1.75; margin-bottom:24px; }
    .hero-kpis { display:grid; grid-template-columns: repeat(4, minmax(120px, 1fr)); gap:14px; margin-bottom:22px; }
    .hero-kpi { padding:16px 18px; border-radius:18px; background: rgba(255,255,255,.62); border:1px solid var(--line); }
    .hero-kpi-num { font-family:'Cormorant Garamond', serif; font-size:34px; }
    .hero-kpi-lbl { font-size:10px; color:var(--muted); text-transform:uppercase; letter-spacing:.16em; margin-top:4px; }
    .logo-strip { display:grid; grid-template-columns: repeat(6, minmax(0,1fr)); gap:12px; }
    .logo-card { height:74px; background: rgba(255,255,255,.65); border:1px solid var(--line); border-radius:18px; display:flex; align-items:center; justify-content:center; padding:14px; }
    .logo-card img { max-height:34px; width:auto; object-fit:contain; filter: grayscale(100%) contrast(1.02) brightness(.78); opacity:.92; }

    .vision-grid { display:none; }

    .section-tabs { display:flex; gap:10px; padding:0 34px 16px; position:sticky; top:0; z-index:5; backdrop-filter: blur(18px); background: linear-gradient(180deg, rgba(245,239,229,.92), rgba(245,239,229,.72), transparent); }
    .stab { padding:13px 16px; border-radius:16px; border:1px solid var(--line); background:rgba(255,255,255,.55); color:var(--muted); font-size:13px; font-weight:600; cursor:pointer; transition:.18s ease; }
    .stab.active, .stab:hover { color:var(--text); background:white; border-color:var(--line-strong); box-shadow:var(--shadow-soft); }
    .entities-row { display:flex; flex-wrap:wrap; gap:8px; padding:0 34px 18px; }

    .panel { display:none; } .panel.active { display:block; }
    .explorer-header { display:flex; gap:12px; align-items:center; padding:0 34px 8px; }
    .explorer-title { color:var(--muted); font-size:13px; }
    .explorer-count { font-family:'Cormorant Garamond', serif; font-size:28px; }
    .sort-btn { margin-left:auto; padding:10px 14px; border-radius:14px; border:1px solid var(--line); background:rgba(255,255,255,.7); color:var(--text); cursor:pointer; }
    .cards-grid { padding:12px 34px 34px; display:grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap:16px; }
    .use-card { background:linear-gradient(180deg, rgba(255,255,255,.86), rgba(255,255,255,.68)); border:1px solid rgba(255,255,255,.78); border-radius:26px; padding:18px; box-shadow:var(--shadow-soft); cursor:pointer; transition:.2s ease; position:relative; overflow:hidden; }
    .use-card::before { content:''; position:absolute; inset:0 auto 0 0; width:4px; background:var(--data); opacity:.85; }
    .use-card.type-ia::before { background:var(--ia); }
    .use-card.type-trans::before { background:var(--trans); }
    .use-card:hover { transform:translateY(-3px); box-shadow:var(--shadow); }
    .card-entity-row { display:flex; justify-content:space-between; align-items:flex-start; gap:10px; margin-bottom:14px; }
    .entity-id { display:flex; align-items:center; gap:12px; min-width:0; }
    .entity-logo { width:42px; height:42px; border-radius:14px; background:rgba(255,255,255,.85); border:1px solid var(--line); display:grid; place-items:center; padding:8px; overflow:hidden; flex-shrink:0; }
    .entity-logo.sm { width:34px; height:34px; border-radius:12px; padding:6px; }
    .entity-logo img { width:100%; height:100%; object-fit:contain; filter: grayscale(100%) contrast(1.02) brightness(.68); }
    .entity-logo.fallback { font-size:11px; font-weight:700; color:var(--muted); letter-spacing:.12em; }
    .entity-name { font-size:12px; font-weight:700; color:var(--text); }
    .entity-detail { font-size:11px; color:var(--muted); margin-top:2px; }
    .prio-dot { width:10px; height:10px; border-radius:50%; margin-top:4px; flex-shrink:0; }
    .card-top { margin-bottom:10px; }
    .card-badges, .panel-eyebrow { display:flex; flex-wrap:wrap; gap:8px; }
    .badge { padding:6px 10px; border-radius:999px; border:1px solid var(--line); font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.12em; background:rgba(255,255,255,.62); }
    .badge-data { color:var(--data); background:var(--data-bg); border-color:var(--data-border); }
    .badge-ia { color:var(--ia); background:var(--ia-bg); border-color:var(--ia-border); }
    .badge-trans { color:var(--trans); background:var(--trans-bg); border-color:var(--trans-border); }
    .badge-lot1 { color:var(--lot1); background:rgba(154,130,96,.10); border-color:rgba(154,130,96,.22); }
    .badge-lot2 { color:var(--lot2); background:rgba(125,107,87,.10); border-color:rgba(125,107,87,.22); }
    .badge-lot3 { color:var(--lot3); background:rgba(194,170,134,.18); border-color:rgba(194,170,134,.32); }
    .badge-p1 { color:var(--priority-1); background:rgba(122,88,69,.08); border-color:rgba(122,88,69,.2); }
    .badge-p2 { color:var(--priority-2); background:rgba(154,119,92,.09); border-color:rgba(154,119,92,.22); }
    .badge-p3 { color:var(--priority-3); background:rgba(143,139,128,.09); border-color:rgba(143,139,128,.22); }
    .badge-p4 { color:var(--priority-4); background:rgba(171,162,149,.12); border-color:rgba(171,162,149,.26); }
    .badge-qw { color:#7a5f3d; background:rgba(217,195,163,.26); border-color:rgba(188,162,127,.34); }
    .card-title { font-size:20px; line-height:1.3; font-weight:700; margin-bottom:8px; }
    .card-summary { font-size:13px; color:var(--muted); line-height:1.65; min-height:64px; }
    .card-footer { display:flex; flex-wrap:wrap; gap:8px; align-items:center; margin-top:14px; }
    .val-tag, .tag-item { padding:8px 10px; border-radius:12px; border:1px solid var(--line); background:rgba(255,255,255,.58); font-size:11px; color:var(--muted); }
    .card-arrow { margin-left:auto; font-size:18px; color:var(--muted); }
    .no-results { padding:60px 20px; text-align:center; color:var(--muted); grid-column:1/-1; }
    .empty-mark { font-size:44px; margin-bottom:10px; color:var(--accent-2); }

    .roadmap-wrap { padding:12px 34px 34px; }
    .roadmap-intro { display:flex; align-items:flex-end; justify-content:space-between; gap:18px; flex-wrap:wrap; }
    .roadmap-intro h2 { font-family:'Cormorant Garamond', serif; font-size:42px; margin-bottom:8px; }
    .roadmap-intro p { color:var(--muted); max-width:760px; line-height:1.7; }
    .roadmap-status { padding:10px 14px; border-radius:999px; border:1px solid var(--line); background:rgba(255,255,255,.74); font-size:12px; color:var(--muted); }
    .lots-grid { display:grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap:18px; margin-top:24px; align-items:start; }
    .lot-col { background:linear-gradient(180deg, rgba(255,255,255,.88), rgba(255,255,255,.66)); border-radius:30px; border:1px solid rgba(255,255,255,.78); box-shadow:var(--shadow-soft); overflow:hidden; position:relative; }
    .lot-col::before { content:''; position:absolute; inset:0 0 auto 0; height:4px; opacity:.95; }
    .lot-col.lot-1::before { background:linear-gradient(90deg, rgba(154,130,96,.9), rgba(154,130,96,.3)); }
    .lot-col.lot-2::before { background:linear-gradient(90deg, rgba(125,107,87,.9), rgba(125,107,87,.3)); }
    .lot-col.lot-3::before { background:linear-gradient(90deg, rgba(194,170,134,.95), rgba(194,170,134,.35)); }
    .lot-header { padding:22px 20px 18px; display:flex; align-items:center; gap:14px; border-bottom:1px solid var(--line); }
    .lot-step { width:46px; height:46px; border-radius:18px; display:grid; place-items:center; font-weight:800; background:rgba(255,255,255,.88); border:1px solid var(--line); box-shadow: inset 0 1px 0 rgba(255,255,255,.65); }
    .lot-copy { flex:1; }
    .lot-title { font-size:17px; font-weight:700; }
    .lot-sub { color:var(--muted); font-size:12px; margin-top:4px; line-height:1.45; }
    .lot-horizon { padding:8px 10px; border-radius:999px; background:rgba(255,255,255,.82); border:1px solid var(--line); font-size:11px; color:var(--muted); white-space:nowrap; }
    .lot-body { padding:16px; display:flex; flex-direction:column; gap:12px; min-height:220px; }
    .road-card { background:rgba(255,255,255,.76); border:1px solid var(--line); border-radius:22px; padding:15px; cursor:pointer; transition:.18s ease; }
    .road-card:hover { transform:translateY(-2px); box-shadow:var(--shadow-soft); }
    .road-card-head { display:flex; align-items:center; gap:10px; margin-bottom:10px; }
    .road-card-ent { font-size:10px; text-transform:uppercase; letter-spacing:.16em; color:var(--muted); }
    .road-card-title { font-size:15px; font-weight:700; margin-bottom:7px; line-height:1.4; }
    .road-card-sum { font-size:12px; line-height:1.6; color:var(--muted); }
    .road-card-footer { display:flex; flex-wrap:wrap; gap:8px; margin-top:12px; }
    .road-empty { border:1px dashed var(--line-strong); border-radius:22px; padding:18px; color:var(--muted); background:rgba(255,255,255,.42); min-height:120px; display:flex; align-items:center; justify-content:center; text-align:center; line-height:1.6; }

    .op-wrap { padding:12px 34px 34px; }
    .op-sections { display:grid; grid-template-columns: 1.1fr .9fr; gap:18px; }
    .op-section { background:var(--panel); border:1px solid rgba(255,255,255,.74); box-shadow:var(--shadow-soft); border-radius:28px; padding:22px; }
    .op-section-title { font-size:22px; font-weight:700; margin-bottom:6px; }
    .op-section-sub { color:var(--muted); font-size:13px; margin-bottom:16px; }
    .team-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
    .role-card, .ent-item, .kpi-box, .card-like { background:rgba(255,255,255,.7); border:1px solid var(--line); border-radius:18px; }
    .role-card { padding:14px; }
    .role-title { font-size:13px; font-weight:700; margin-bottom:4px; }
    .role-desc { font-size:12px; color:var(--muted); line-height:1.55; }
    .budget-bars { display:flex; flex-direction:column; gap:12px; }
    .bbar-top { display:flex; justify-content:space-between; gap:12px; margin-bottom:6px; }
    .bbar-lbl { font-size:13px; color:var(--text); }
    .bbar-pct { font-size:12px; color:var(--muted); font-weight:700; }
    .bbar-track { height:10px; border-radius:999px; background:rgba(255,255,255,.62); border:1px solid var(--line); overflow:hidden; }
    .bbar-fill { height:100%; border-radius:999px; }
    .entites-list { display:grid; gap:10px; }
    .ent-item { display:flex; align-items:center; gap:12px; padding:12px; cursor:pointer; transition:.18s ease; }
    .ent-item:hover { transform:translateY(-2px); box-shadow:var(--shadow-soft); }
    .ent-name { font-weight:700; }
    .ent-role { color:var(--muted); font-size:12px; }
    .ent-count { margin-left:auto; padding:6px 10px; border-radius:999px; border:1px solid var(--line); background:white; font-size:11px; }

    .detail-overlay { position:fixed; inset:0; background:rgba(43,36,29,.28); backdrop-filter: blur(8px); opacity:0; pointer-events:none; transition:.2s ease; z-index:40; }
    .detail-overlay.open { opacity:1; pointer-events:auto; }
    .detail-panel { position:fixed; top:0; right:0; width:min(740px, 100vw); height:100vh; background:linear-gradient(180deg, #f7f1e8, #efe7da); border-left:1px solid var(--line); transform:translateX(100%); transition:.24s ease; z-index:50; display:flex; flex-direction:column; }
    .detail-panel.open { transform:translateX(0); }
    .panel-header { padding:22px 24px 10px; display:flex; gap:12px; align-items:flex-start; border-bottom:1px solid var(--line); background:rgba(247,241,232,.86); backdrop-filter:blur(16px); }
    .panel-close { margin-left:auto; width:40px; height:40px; border-radius:14px; border:1px solid var(--line); background:rgba(255,255,255,.8); cursor:pointer; color:var(--muted); }
    .panel-body { padding:22px 24px; overflow:auto; }
    .panel-title { font-family:'Cormorant Garamond', serif; font-size:42px; line-height:1.02; margin-bottom:12px; }
    .panel-summary { padding:18px 20px; border-radius:22px; background:rgba(255,255,255,.76); border:1px solid var(--line); line-height:1.75; color:var(--muted); margin-bottom:18px; }
    .detail-grid, .split { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
    .detail-section { margin-bottom:14px; }
    .card-like { padding:16px; }
    .detail-section-title { font-size:10px; text-transform:uppercase; letter-spacing:.18em; color:var(--muted); margin-bottom:10px; }
    .detail-text { color:var(--text); line-height:1.72; font-size:14px; }
    .kpi-row { display:grid; grid-template-columns:repeat(auto-fill,minmax(160px,1fr)); gap:10px; }
    .kpi-box { padding:12px 14px; font-size:12px; line-height:1.55; }
    .horizon-badge { padding:10px 12px; border-radius:16px; border:1px solid var(--line); background:white; display:inline-flex; font-weight:700; }
    .comex-box { padding:18px 20px; border-radius:22px; background:linear-gradient(135deg, rgba(255,255,255,.88), rgba(217,195,163,.25)); border:1px solid rgba(188,162,127,.35); line-height:1.75; font-style:italic; }
    .nav-cards-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; padding:16px 24px 22px; border-top:1px solid var(--line); background:rgba(247,241,232,.9); }
    .nav-card-btn { border:1px solid var(--line); background:rgba(255,255,255,.78); border-radius:18px; padding:14px; display:flex; align-items:center; justify-content:space-between; gap:12px; cursor:pointer; text-align:left; }
    .nav-card-btn[disabled] { opacity:.45; cursor:not-allowed; }
    .nav-card-btn-lbl { font-size:10px; text-transform:uppercase; letter-spacing:.16em; color:var(--muted); margin-bottom:4px; }
    .nav-card-btn-title { font-size:12px; font-weight:700; color:var(--text); line-height:1.45; }
    .nav-arrow { font-size:18px; color:var(--muted); }
    .highlighted { background:rgba(217,195,163,.55); border-radius:4px; padding:0 2px; }

    @media (max-width: 1200px) { .app { grid-template-columns: 280px 1fr; } .vision-grid,.hero-kpis,.logo-strip,.lots-grid { grid-template-columns: repeat(2,1fr); } }
