function renderAll() {
  renderCards();
  renderRoadmap();
}

function filterDim(v, btn) {
  state.dim = v;
  document.querySelectorAll('#dimFilter .fchip').forEach(b => b.className = 'fchip');
  btn.classList.add(v === 'all' ? 'active-all' : v === 'Data' ? 'active-data' : v === 'IA' ? 'active-ia' : 'active-trans');
  renderAll();
}
function filterEntity(v) {
  state.entity = v;
  document.querySelectorAll('.ent-chip').forEach(c => {
    c.classList.remove('active');
    const val = c.textContent.trim();
    if ((v === 'all' && val === 'Toutes les entités') || val.startsWith(v.split('/')[0].trim())) c.classList.add('active');
  });
  renderAll();
}
function filterEntityChip(v, btn) {
  state.entity = v;
  document.querySelectorAll('.ent-chip').forEach(c => c.classList.remove('active'));
  if (btn) btn.classList.add('active');
  document.getElementById('entitySelect').value = v;
  renderAll();
}
function filterLot(v, btn) {
  state.lot = v;
  document.querySelectorAll('#lotPills .nav-pill').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderAll();
}
function filterPrio(v, btn) {
  state.priority = v;
  document.querySelectorAll('#prioFilter .fchip').forEach(b => b.className = 'fchip');
  btn.classList.add(v === 'all' ? 'active-all' : 'active-p1');
  renderAll();
}
function filterValue(v) { state.value = v; renderAll(); }
function toggleQW(btn) {
  state.quickwin = !state.quickwin;
  btn.classList.toggle('active-trans', state.quickwin);
  renderAll();
}
function cycleSortMode() {
  sortIdx = (sortIdx + 1) % SORT_MODES.length;
  state.sort = SORT_MODES[sortIdx];
  document.getElementById('sortLabel').textContent = SORT_LABELS[state.sort];
  renderAll();
}

document.getElementById('searchInput').addEventListener('input', function() {
  state.search = this.value.toLowerCase();
  renderAll();
});

// ═══════════════════════════════════════════════════════════
//  PRIORITY ORDER
// ═══════════════════════════════════════════════════════════
const PRIO_ORDER = { 'Très prioritaire':0, 'Prioritaire':1, 'Structurant':2, 'Vision long terme':3 };
const LOT_ORDER  = { 'Lot 1':0, 'Lot 2':1, 'Lot 3':2 };
 
function getPrioBadgeClass(p) {
  return p === 'Très prioritaire' ? 'badge-p1' : p === 'Prioritaire' ? 'badge-p2' : p === 'Structurant' ? 'badge-p3' : 'badge-p4';
}
function getLotBadgeClass(l) {
  return l === 'Lot 1' ? 'badge-lot1' : l === 'Lot 2' ? 'badge-lot2' : 'badge-lot3';
}
function getDimBadgeClass(d) {
  return d === 'Data' ? 'badge-data' : d === 'IA' ? 'badge-ia' : 'badge-trans';
}
function getCardTypeClass(d) {
  return d === 'Data' ? 'type-data' : d === 'IA' ? 'type-ia' : 'type-trans';
}
 
// ═══════════════════════════════════════════════════════════
//  RENDER CARDS
// ═══════════════════════════════════════════════════════════
function matchesFilters(uc) {
  if (state.dim !== 'all' && uc.dim !== state.dim) return false;
  if (state.entity !== 'all' && !uc.entity.startsWith(state.entity.split('/')[0].trim()) && uc.entity !== state.entity) return false;
  if (state.lot !== 'all' && uc.lot !== state.lot) return false;
  if (state.priority !== 'all' && uc.priority !== state.priority) return false;
  if (state.value !== 'all' && !uc.value.includes(state.value)) return false;
  if (state.quickwin && !uc.quickwin) return false;
  if (state.search) {
    const hay = (uc.title + ' ' + uc.entity + ' ' + uc.summary + ' ' + (uc.tech||[]).join(' ')).toLowerCase();
    if (!hay.includes(state.search)) return false;
  }
  return true;
}
 
function highlight(text) {
  if (!state.search) return text;
  const escaped = state.search.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  const re = new RegExp(`(${escaped})`, 'gi');
  return text.replace(re, '<mark class="highlighted">$1</mark>');
}

function getFilteredCases() {
  return USE_CASES.filter(matchesFilters);
}

function updateRoadmapStatus(filtered) {
  const el = document.getElementById('roadmapStatus');
  if (!el) return;
  const active = [];
  if (state.dim !== 'all') active.push(state.dim);
  if (state.entity !== 'all') active.push(state.entity);
  if (state.lot !== 'all') active.push(state.lot);
  if (state.priority !== 'all') active.push(state.priority);
  if (state.value !== 'all') active.push(state.value);
  if (state.quickwin) active.push('Quick wins');
  if (state.search) active.push(`Recherche : ${state.search}`);
  el.textContent = active.length ? `${filtered.length} use cases affichés · ${active.join(' · ')}` : 'Vue complète';
}
 
// ═══════════════════════════════════════════════════════════
//  ROADMAP RENDER
// ═══════════════════════════════════════════════════════════
// ═══════════════════════════════════════════════════════════
//  DETAIL PANEL
// ═══════════════════════════════════════════════════════════
function closePanel() {
  document.getElementById('overlay').classList.remove('open');
  document.getElementById('detailPanel').classList.remove('open');
  currentId = null;
}
 
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closePanel();
});
 
// ═══════════════════════════════════════════════════════════
//  TABS
// ═══════════════════════════════════════════════════════════
function showTab(id, btn) {
  document.querySelectorAll('.stab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.getElementById('panel-' + id).classList.add('active');
  document.getElementById('entRow').style.display = (id === 'explorer') ? 'flex' : 'none';
  if (id === 'roadmap') renderRoadmap();
}
 
// ═══════════════════════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════════════════════


function renderCards() {
  const grid = document.getElementById('cardsGrid');
  let filtered = getFilteredCases();
  filtered.sort((a,b) => {
    if (state.sort === 'priority') return (PRIO_ORDER[a.priority]||9) - (PRIO_ORDER[b.priority]||9);
    if (state.sort === 'lot')      return (LOT_ORDER[a.lot]||9) - (LOT_ORDER[b.lot]||9);
    if (state.sort === 'entity')   return a.entity.localeCompare(b.entity);
    return a.title.localeCompare(b.title);
  });

  document.getElementById('visibleCount').textContent = filtered.length;
  document.getElementById('totalCount').textContent = USE_CASES.length;

  if (!filtered.length) {
    grid.innerHTML = '<div class="no-results"><div class="empty-mark">◌</div><p>Aucun use case ne correspond aux filtres sélectionnés.</p></div>';
    return;
  }

  grid.innerHTML = filtered.map((uc, i) => {
    const valTags = uc.value.slice(0,2).map(v => `<span class="val-tag">${v}</span>`).join('');
    return `
    <article class="use-card ${getCardTypeClass(uc.dim)}" style="animation-delay:${i*0.03}s" onclick="openDetail('${uc.id}')">
      <div class="card-entity-row">
        ${entityLabelHTML(uc.entity, uc.lot)}
        <div class="prio-dot" style="background:${uc.priority==='Très prioritaire'?'var(--priority-1)':uc.priority==='Prioritaire'?'var(--priority-2)':'var(--priority-3)'}"></div>
      </div>
      <div class="card-top">
        <div class="card-badges">
          <span class="badge ${getDimBadgeClass(uc.dim)}">${uc.dim}</span>
          <span class="badge ${getLotBadgeClass(uc.lot)}">${uc.lot}</span>
          ${uc.quickwin ? '<span class="badge badge-qw">Quick win</span>' : ''}
        </div>
      </div>
      <h3 class="card-title">${highlight(uc.title)}</h3>
      <p class="card-summary">${highlight(uc.summary)}</p>
      <div class="card-footer">
        ${valTags}
        <span class="card-arrow">→</span>
      </div>
    </article>`;
  }).join('');
}


function renderRoadmap() {
  const lots = ['Lot 1','Lot 2','Lot 3'];
  const grid = document.getElementById('lotsGrid');
  const filtered = getFilteredCases();
  updateRoadmapStatus(filtered);

  grid.innerHTML = lots.map(lotKey => {
    const meta = LOT_META[lotKey];
    const items = filtered
      .filter(u => u.lot === lotKey)
      .sort((a,b) => (PRIO_ORDER[a.priority]||9) - (PRIO_ORDER[b.priority]||9));

    const cards = items.length ? items.map(uc => `
      <article class="road-card" onclick="openDetail('${uc.id}')">
        <div class="road-card-head">
          ${entityLogoHTML(uc.entity, 'entity-logo sm')}
          <div class="road-card-ent">${getEntityMeta(uc.entity).label}</div>
        </div>
        <div class="road-card-title">${highlight(uc.title)}</div>
        <div class="road-card-sum">${highlight(uc.summary)}</div>
        <div class="road-card-footer">
          <span class="badge ${getDimBadgeClass(uc.dim)}">${uc.dim}</span>
          <span class="badge ${getPrioBadgeClass(uc.priority)}">${uc.priority}</span>
          ${uc.quickwin ? '<span class="badge badge-qw">Quick win</span>' : ''}
        </div>
      </article>`).join('') : `<div class="road-empty">Aucun sujet ne correspond aux filtres actifs pour ${lotKey.toLowerCase()}.</div>`;

    return `
      <section class="lot-col ${lotKey.toLowerCase().replace(' ','-')}">
        <header class="lot-header">
          <div class="lot-step">${lotKey.replace('Lot ','')}</div>
          <div class="lot-copy">
            <div class="lot-title">${meta.title}</div>
            <div class="lot-sub">${meta.subtitle}</div>
          </div>
          <div class="lot-horizon">${meta.horizon}</div>
        </header>
        <div class="lot-body">${cards}</div>
      </section>`;
  }).join('');
}

let currentId = null;
function openDetail(id) {
  currentId = id;
  const uc = USE_CASES.find(u => u.id === id);
  if (!uc) return;

  const eyebrow = document.getElementById('panelEyebrow');
  eyebrow.innerHTML = `
    ${entityLabelHTML(uc.entity)}
    <span class="badge ${getDimBadgeClass(uc.dim)}">${uc.dim}</span>
    <span class="badge ${getLotBadgeClass(uc.lot)}">${uc.lot}</span>
    <span class="badge ${getPrioBadgeClass(uc.priority)}">${uc.priority}</span>
    ${uc.quickwin ? '<span class="badge badge-qw">Quick win</span>' : ''}
  `;

  const body = document.getElementById('panelBody');
  body.innerHTML = `
    <div class="panel-title">${uc.title}</div>
    <div class="panel-summary">${uc.summary}</div>
    <div class="detail-grid">
      <div class="detail-section card-like">
        <div class="detail-section-title">Problème actuel</div>
        <div class="detail-text">${uc.problem}</div>
      </div>
      <div class="detail-section card-like">
        <div class="detail-section-title">Objectif visé</div>
        <div class="detail-text">${uc.objective}</div>
      </div>
    </div>
    <div class="detail-section card-like">
      <div class="detail-section-title">Approche recommandée</div>
      <div class="detail-text">${uc.how}</div>
    </div>
    <div class="detail-section card-like">
      <div class="detail-section-title">Sources de données</div>
      <div class="tag-list">${uc.sources.map(s=>`<span class="tag-item">${s}</span>`).join('')}</div>
    </div>
    <div class="detail-section card-like">
      <div class="detail-section-title">Technologies & stack</div>
      <div class="tag-list">${uc.tech.map(t=>`<span class="tag-item">${t}</span>`).join('')}</div>
    </div>
    <div class="detail-section card-like">
      <div class="detail-section-title">Livrables & KPI</div>
      <div class="kpi-row">${uc.deliverables.map(d=>`<div class="kpi-box">${d}</div>`).join('')}</div>
    </div>
    <div class="detail-section card-like">
      <div class="detail-section-title">Dépendances & prérequis</div>
      <div class="tag-list">${uc.dependencies.map(d=>`<span class="tag-item">${d}</span>`).join('')}</div>
    </div>
    <div class="detail-section split">
      <div class="card-like">
        <div class="detail-section-title">Horizon</div>
        <div class="horizon-badge"><span>${uc.horizon}</span></div>
      </div>
      <div class="card-like">
        <div class="detail-section-title">Valeur métier</div>
        <div class="tag-list">${uc.value.map(v=>`<span class="tag-item">${v}</span>`).join('')}</div>
      </div>
    </div>
    <div class="detail-section">
      <div class="detail-section-title">Lecture COMEX</div>
      <div class="comex-box">${uc.comex}</div>
    </div>`;

  const all = USE_CASES;
  const idx = all.findIndex(u => u.id === id);
  const prev = all[idx - 1];
  const next = all[idx + 1];
  document.getElementById('panelNav').innerHTML = `
    <button class="nav-card-btn" ${prev ? `onclick="openDetail('${prev.id}')"` : 'disabled'}>
      <span class="nav-arrow">←</span>
      <div><div class="nav-card-btn-lbl">Précédent</div><div class="nav-card-btn-title">${prev ? prev.title : '—'}</div></div>
    </button>
    <button class="nav-card-btn" ${next ? `onclick="openDetail('${next.id}')"` : 'disabled'}>
      <div><div class="nav-card-btn-lbl">Suivant</div><div class="nav-card-btn-title">${next ? next.title : '—'}</div></div>
      <span class="nav-arrow">→</span>
    </button>`;

  document.getElementById('overlay').classList.add('open');
  document.getElementById('detailPanel').classList.add('open');
}

renderAll();
</script>
